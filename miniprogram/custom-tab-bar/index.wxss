.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  padding: 8rpx 0 calc(8rpx + env(safe-area-inset-bottom));
  z-index: 9999;
}

.tab-bar-border {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 1rpx;
  background: rgba(0, 0, 0, 0.08);
  transform: scaleY(0.5);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rpx 0;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
}

.tab-bar-text {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.2;
  color: #B0B0B0;
}

.tab-bar-item.active .tab-bar-text {
  color: #4CAF50;
}
