page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.5;
}

button {
  border: none;
  outline: none;
}

button::after {
  border: none;
}

.accent-green {
  color: #4CAF50;
}

.accent-orange {
  color: #FF9800;
}
