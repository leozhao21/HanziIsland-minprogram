.home-page {
  min-height: 100vh;
  padding: 32rpx 48rpx 80rpx;
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.25) 0%, rgba(255, 152, 0, 0.12) 40%, #fff 100%);
  box-sizing: border-box;
  position: relative;
}

.parent-btn {
  position: absolute;
  top: 16rpx;
  right: 32rpx;
  font-size: 40rpx;
  opacity: 0.5;
  padding: 16rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
  margin-bottom: 48rpx;
}

.island-emoji {
  font-size: 120rpx;
}

.app-title {
  font-size: 72rpx;
  font-weight: 700;
  margin-top: 16rpx;
}

.star-row {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.star-emoji {
  font-size: 48rpx;
}

.star-count {
  font-size: 64rpx;
  font-weight: 700;
  color: #FF9800;
  margin-left: 8rpx;
}

.progress-card {
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 48rpx;
}

.progress-title {
  font-size: 32rpx;
  font-weight: 700;
  display: block;
  margin-bottom: 24rpx;
}

.start-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #4CAF50, #66BB6A);
  color: #fff;
  border-radius: 48rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 24rpx rgba(76, 175, 80, 0.35);
}

.start-btn[disabled] {
  opacity: 0.5;
}

.btn-emoji {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-size: 48rpx;
  font-weight: 700;
}

.retry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 152, 0, 0.15);
  border-radius: 40rpx;
  padding: 32rpx;
}

.retry-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FF9800;
}
