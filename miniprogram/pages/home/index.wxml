<view class="home-page">
  <view class="parent-btn" bindtap="onOpenParent">👤</view>

  <view class="header">
    <text class="island-emoji">🏝️</text>
    <text class="app-title">识字岛</text>
    <view class="star-row">
      <text class="star-emoji">⭐</text>
      <text class="star-count">{{starCount}}</text>
    </view>
  </view>

  <view class="progress-card">
    <text wx:if="{{isGoalMet}}" class="progress-title">🎉 今天太棒啦！</text>
    <text wx:else class="progress-title">今天已学 {{studiedCount}} 个字</text>
    <progress percent="{{progressPercent}}" activeColor="#4CAF50" backgroundColor="#eee" stroke-width="12" border-radius="8" />
  </view>

  <view
    class="start-btn {{canStart ? '' : 'is-disabled'}}"
    hover-class="{{canStart ? 'start-btn--pressed' : ''}}"
    hover-stay-time="100"
    bindtap="onStartLearn"
  >
    <view class="start-btn-inner">
      <view class="btn-icon-wrap start-icon">🚀</view>
      <text class="btn-text">开始学汉字</text>
    </view>
  </view>

  <view
    wx:if="{{hasIntensiveReview}}"
    class="retry-btn"
    hover-class="retry-btn--pressed"
    hover-stay-time="100"
    bindtap="onRetryWrong"
  >
    <view class="retry-btn-inner">
      <view class="btn-icon-wrap retry-icon">💪</view>
      <text class="retry-text">再练一遍错题</text>
    </view>
  </view>
</view>
