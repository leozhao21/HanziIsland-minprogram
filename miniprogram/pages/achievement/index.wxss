.achievement-page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f0f0f0;
  box-sizing: border-box;
}

.header-card {
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.header-title { font-size: 36rpx; font-weight: 700; display: block; }
.header-sub { font-size: 26rpx; color: #666; display: block; margin: 8rpx 0 16rpx; }
.header-stats {
  display: flex; justify-content: space-between;
  background: rgba(0,0,0,0.04); border-radius: 16rpx; padding: 20rpx;
  font-weight: 700;
}

.section {
  background: #fff; border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx;
}
.section-title { font-weight: 700; font-size: 30rpx; display: block; margin-bottom: 16rpx; }

.badge-scroll { white-space: nowrap; }
.badge {
  display: inline-flex; flex-direction: column; align-items: center;
  width: 160rpx; padding: 16rpx; margin-right: 16rpx;
  background: #f5f5f5; border-radius: 16rpx; opacity: 0.4;
}
.badge.earned { opacity: 1; background: rgba(76,175,80,0.15); }
.badge-emoji { font-size: 56rpx; }
.badge-title { font-size: 22rpx; margin-top: 8rpx; }
.badge-threshold { font-size: 20rpx; color: #666; }

.level-row {
  margin-bottom: 20rpx;
  display: grid; grid-template-columns: 120rpx 100rpx 1fr; align-items: center; gap: 12rpx;
}
.level-count { text-align: right; color: #666; font-size: 26rpx; }
