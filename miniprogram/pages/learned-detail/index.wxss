.detail-page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f0f0f0;
  box-sizing: border-box;
}

.big-char { font-size: 160rpx; font-weight: 700; }
.char-row { display: flex; align-items: center; justify-content: center; gap: 24rpx; }
.pinyin { display: block; text-align: center; font-size: 48rpx; color: #666; margin: 16rpx 0; }

.sentence-row {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 24rpx 0;
}
.sentence { flex: 1; font-size: 36rpx; }

.audio-btn {
  background: rgba(76, 175, 80, 0.15);
  color: #4CAF50;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: inline-block;
  margin-top: 16rpx;
}
.audio-btn.small { padding: 8rpx 16rpx; margin-top: 0; }

.section {
  border-radius: 24rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}
.section.orange { background: rgba(255, 152, 0, 0.08); }
.section.purple { background: rgba(156, 39, 176, 0.08); }
.section.blue { background: rgba(33, 150, 243, 0.08); }
.section-title { font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; }
.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.section-header .section-title { margin-bottom: 0; flex: 1; }
.section-header .audio-btn.compact { margin: 0; flex-shrink: 0; padding: 8rpx 20rpx; font-size: 24rpx; }
.tag {
  font-size: 24rpx;
  background: rgba(156, 39, 176, 0.12);
  color: #9C27B0;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
}

.components { display: flex; flex-wrap: wrap; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.comp {
  font-size: 56rpx;
  font-weight: 700;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}
.comp.highlight { background: rgba(255, 152, 0, 0.22); border: 2rpx solid rgba(255, 152, 0, 0.35); }
.plus { font-size: 40rpx; color: rgba(255, 152, 0, 0.7); font-weight: 700; }
.plus.blue { color: rgba(33, 150, 243, 0.7); }
.section-desc {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.65;
  margin-top: 8rpx;
}
.pinyin-formula,
.pinyin-whole {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.py-part {
  font-size: 44rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}
.py-part.initial {
  color: #1565C0;
  background: rgba(21, 101, 192, 0.12);
}
.py-part.medial {
  color: #6A1B9A;
  background: rgba(106, 27, 154, 0.12);
}
.py-part.final {
  color: #E65100;
  background: rgba(230, 81, 0, 0.12);
}
.py-part.full {
  color: #2E7D32;
  background: rgba(46, 125, 50, 0.12);
}
.tone-info { margin-top: 12rpx; }
.tone-label {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #7B1FA2;
  margin-bottom: 4rpx;
}

.stats-card {
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 32rpx;
}
.stats-header { display: flex; justify-content: space-between; margin-bottom: 16rpx; }
.stats-title { font-weight: 700; font-size: 30rpx; }
.stats-value { font-weight: 700; color: #4CAF50; }
.stats-detail { display: block; font-size: 26rpx; color: #666; margin-top: 12rpx; }
.intensive { display: block; color: #FF9800; font-weight: 700; margin-top: 12rpx; font-size: 26rpx; }

.retest-btn {
  margin-top: 32rpx;
  background: linear-gradient(90deg, #FF9800, #FFB74D);
  color: #fff;
  border-radius: 40rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx;
}
