.learned-page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(33, 150, 243, 0.12) 0%, rgba(76, 175, 80, 0.08) 30%, #fff 100%);
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.header-emoji { font-size: 96rpx; }
.header-title { font-size: 56rpx; font-weight: 700; margin-top: 8rpx; }

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-card.active {
  background: rgba(76, 175, 80, 0.18);
}

.stat-emoji { font-size: 40rpx; }
.stat-count { font-size: 48rpx; font-weight: 700; margin: 8rpx 0; }
.stat-label { font-size: 22rpx; color: #666; font-weight: 700; }

.filter-scroll { white-space: nowrap; margin-bottom: 24rpx; }
.filter-row { display: inline-flex; gap: 16rpx; }
.filter-chip {
  display: inline-block;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  font-weight: 700;
}
.filter-chip.active { background: #4CAF50; color: #fff; }

.empty {
  text-align: center;
  padding: 80rpx 24rpx;
}
.empty-emoji { font-size: 100rpx; display: block; }
.empty-title { font-size: 32rpx; font-weight: 700; display: block; margin-top: 24rpx; }
.empty-hint { font-size: 28rpx; color: #666; display: block; margin-top: 16rpx; }

.list-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.char {
  font-size: 72rpx;
  font-weight: 700;
  width: 100rpx;
  text-align: center;
}

.info { flex: 1; margin: 0 16rpx; overflow: hidden; }
.pinyin { font-size: 28rpx; color: #666; display: block; }
.sentence { font-size: 24rpx; color: #999; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.status { text-align: center; }
.status-emoji { font-size: 40rpx; display: block; }
.status-label { font-size: 20rpx; color: #666; font-weight: 700; }
