.bootstrap-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.25) 0%, #fff 60%);
  padding: 40rpx;
}

.emoji {
  font-size: 120rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  margin-top: 24rpx;
}

.status {
  margin-top: 24rpx;
  color: #666;
  font-size: 28rpx;
}

.error {
  margin-top: 40rpx;
  text-align: center;
}

.retry-btn {
  margin-top: 24rpx;
  background: #4CAF50;
  color: #fff;
}

.loading {
  margin-top: 40rpx;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #eee;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
