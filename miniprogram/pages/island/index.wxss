.island-page {
  min-height: 100vh;
  padding: 32rpx;
  background: linear-gradient(180deg, rgba(255, 152, 0, 0.1) 0%, #fff 100%);
  box-sizing: border-box;
}

.star-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: linear-gradient(135deg, rgba(255, 235, 59, 0.35), rgba(255, 152, 0, 0.2));
  border-radius: 40rpx;
  margin-bottom: 32rpx;
}

.star-emoji { font-size: 80rpx; }
.star-count { font-size: 96rpx; font-weight: 700; color: #FF9800; margin-left: 16rpx; }

.subtitle {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
}

.island-card {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.island-emoji { font-size: 88rpx; margin-right: 24rpx; }
.island-info { flex: 1; }
.island-name { display: block; font-size: 36rpx; font-weight: 700; }
.island-cost { display: block; font-size: 28rpx; color: #666; margin-top: 8rpx; }
.celebrate { font-size: 56rpx; }

.unlock-btn {
  background: linear-gradient(90deg, #FF9800, #FFB74D);
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  padding: 16rpx 32rpx;
  border-radius: 999rpx;
  margin: 0;
}

.unlock-btn[disabled] { opacity: 0.4; }

.message {
  display: block;
  text-align: center;
  color: #FF9800;
  font-weight: 700;
  font-size: 30rpx;
  margin-top: 16rpx;
}

.achievement-link {
  text-align: center;
  margin-top: 48rpx;
  padding: 24rpx;
  color: #4CAF50;
  font-weight: 700;
  font-size: 30rpx;
}
