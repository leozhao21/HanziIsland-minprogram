.quiz-page {
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(76, 175, 80, 0.12) 0%, #fff 100%);
  padding: 0 24rpx 24rpx;
  box-sizing: border-box;
}

.nav-bar {
  box-sizing: border-box;
  margin: 0 -24rpx 24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.nav-inner {
  display: flex;
  align-items: center;
}

.safe-top {
  margin: 0 -24rpx;
}

.home-btn { font-size: 44rpx; padding: 0 16rpx; }
.phase-title { flex: 1; text-align: center; font-weight: 700; font-size: 30rpx; margin-right: 60rpx; }

.learn-scroll { max-height: 70vh; }
.big-char { font-size: 160rpx; font-weight: 700; display: block; text-align: center; }
.char-row { display: flex; align-items: center; justify-content: center; gap: 16rpx; }
.pinyin { display: block; text-align: center; font-size: 44rpx; color: #666; margin: 16rpx 0; }

.sentence-row {
  display: flex; align-items: center;
  background: #f5f5f5; border-radius: 24rpx; padding: 24rpx; margin: 16rpx 0;
}
.sentence { flex: 1; font-size: 32rpx; }

.audio-btn {
  background: rgba(76, 175, 80, 0.15); color: #4CAF50;
  padding: 12rpx 24rpx; border-radius: 999rpx;
  font-size: 26rpx; font-weight: 700; display: inline-block; margin: 12rpx 0;
}
.audio-btn.small { padding: 8rpx 16rpx; margin: 0; }

.section { border-radius: 24rpx; padding: 24rpx; margin-top: 16rpx; }
.section.orange { background: rgba(255, 152, 0, 0.08); }
.section.purple { background: rgba(156, 39, 176, 0.08); }
.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.section-title { font-size: 32rpx; font-weight: 700; flex: 1; }
.section-header .audio-btn.compact { margin: 0; flex-shrink: 0; padding: 8rpx 20rpx; font-size: 24rpx; }
.tag {
  font-size: 22rpx;
  background: rgba(156, 39, 176, 0.12);
  color: #9C27B0;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  margin-left: 8rpx;
  font-weight: 700;
  vertical-align: middle;
}
.components {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.comp {
  font-size: 48rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.7);
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}
.comp.highlight { background: rgba(255, 152, 0, 0.22); border: 2rpx solid rgba(255, 152, 0, 0.35); }
.plus { font-size: 36rpx; color: rgba(255, 152, 0, 0.7); font-weight: 700; }
.section-desc {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.65;
  margin-top: 8rpx;
}

.learn-done-btn {
  margin-top: 24rpx;
  background: linear-gradient(90deg, #4CAF50, #66BB6A);
  color: #fff; border-radius: 40rpx;
  font-size: 36rpx; font-weight: 700; padding: 28rpx;
}

.listen-prompt { text-align: center; margin-bottom: 32rpx; }
.listen-title { display: block; font-size: 36rpx; font-weight: 700; margin-bottom: 16rpx; }

.prompt-card {
  background: #f5f5f5; border-radius: 24rpx; padding: 24rpx; margin-bottom: 24rpx;
}
.prompt-text { font-size: 36rpx; display: block; margin-bottom: 12rpx; }

.options { display: flex; flex-direction: column; gap: 20rpx; }
.option {
  background: #f5f5f5; border-radius: 24rpx;
  padding: 32rpx; text-align: center; font-weight: 700;
}
.option.correct { background: rgba(76, 175, 80, 0.35); }
.option.wrong { background: rgba(244, 67, 54, 0.3); }
.option.dim { opacity: 0.55; }

.result-area { text-align: center; margin-top: 32rpx; }
.result-text { font-size: 56rpx; font-weight: 700; display: block; margin-bottom: 24rpx; }
.continue-btn {
  background: #FF9800; color: #fff; border-radius: 40rpx;
  font-size: 32rpx; font-weight: 700; padding: 24rpx 48rpx;
}

.done-phase {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 80rpx;
}
.done-emoji { font-size: 160rpx; }
.done-title { font-size: 56rpx; font-weight: 700; margin: 24rpx 0; }
.star-reward { font-size: 72rpx; font-weight: 700; color: #FF9800; margin-bottom: 48rpx; }
.finish-btn {
  background: linear-gradient(90deg, #4CAF50, #66BB6A);
  color: #fff; border-radius: 40rpx; font-size: 32rpx; font-weight: 700; padding: 28rpx 48rpx;
}

.modal-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,0.4);
  display: flex; align-items: center; justify-content: center; z-index: 100;
}
.modal {
  background: #fff; border-radius: 24rpx; padding: 40rpx; width: 80%;
}
.modal-title { display: block; text-align: center; font-size: 32rpx; font-weight: 700; margin-bottom: 32rpx; }
.modal-actions { display: flex; gap: 16rpx; }
.modal-actions button { flex: 1; font-size: 28rpx; }
.modal-actions .destructive { color: #f44336; }
